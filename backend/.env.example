# Mode
PAPER_TRADING=true          # true = paper trade, false = live

# Bybit API (get from bybit.com → API Management)
BYBIT_API_KEY=your_api_key
BYBIT_SECRET=your_secret
BYBIT_TESTNET=false         # true for testnet

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Server
PORT=3001
API_SECRET=your_dashboard_secret

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Grid Config
SYMBOL=HYPEUSDT
GRID_CAPITAL=250
GRID_LEVELS=25
LEVERAGE=10

# Paper trading account balance (fake money total account)
PAPER_BALANCE=250
